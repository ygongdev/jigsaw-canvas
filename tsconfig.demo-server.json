{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "declaration": false,
    "ignoreDeprecations": "6.0",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "outDir": "demo-dist/multiplayer-server",
    "rootDir": "multiplayer-demo/server",
    "sourceMap": false,
    "types": ["node"]
  },
  "include": ["multiplayer-demo/server/**/*.ts"],
  "exclude": ["node_modules", "demo-dist"]
}
