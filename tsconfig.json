{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2020"],
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "demo.ts",
    "multiplayer-demo/client/**/*.ts",
    "src/**/*.ts",
    "test/**/*.ts",
    "tests/**/*.ts",
    "*.config.ts"
  ],
  "exclude": ["node_modules", "dist", "demo-dist"]
}
