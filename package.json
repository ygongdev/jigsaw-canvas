{
  "name": "jigsaw-canvas",
  "version": "0.2.0",
  "description": "A jigsaw piece generator for use with canvas",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": "https://github.com/ygongdev/jigsaw-canvas",
  "author": "Yicheng Gong <ygongdev@gmail.com>",
  "license": "MIT",
  "scripts": {
    "build": "yarn build:lib && yarn build:demos",
    "build:demo": "node ./node_modules/vite/bin/vite.js build --config vite.demo.config.ts",
    "build:demos": "yarn build:demo && yarn build:multiplayer-client && yarn build:multiplayer-server",
    "build:lib": "node ./node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "build:multiplayer-client": "node ./node_modules/vite/bin/vite.js build --config vite.multiplayer-client.config.ts",
    "build:multiplayer-server": "node ./node_modules/typescript/bin/tsc -p tsconfig.demo-server.json && node -e \"require('fs').writeFileSync('demo-dist/multiplayer-server/package.json', JSON.stringify({ type: 'commonjs' }, null, 2))\"",
    "dev:demo": "node ./node_modules/vite/bin/vite.js --config vite.demo.config.ts --host localhost",
    "dev:multiplayer-client": "node ./node_modules/vite/bin/vite.js --config vite.multiplayer-client.config.ts --host localhost",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "prepack": "yarn build:lib",
    "start:multiplayer-server": "node demo-dist/multiplayer-server/server.js",
    "test": "yarn build:lib && node --test tests/*.test.mjs",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit && node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.demo-server.json",
    "release": "release-it"
  },
  "devDependencies": {
    "@types/node": "*",
    "eslint": "^10.6.0",
    "express": "^4.17.1",
    "http": "^0.0.1-security",
    "release-it": "^14.10.0",
    "socket.io": "^4.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0"
  },
  "dependencies": {}
}
