{
  "name": "jigsaw-canvas",
  "version": "0.2.0",
  "description": "A jigsaw piece generator for use with canvas",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": "https://github.com/ygongdev/jigsaw-canvas",
  "author": "Yicheng Gong <ygongdev@gmail.com>",
  "license": "MIT",
  "scripts": {
    "build": "yarn build:lib && yarn build:demos",
    "build:demos": "node ./node_modules/typescript/bin/tsc -p tsconfig.demos.json && node ./node_modules/typescript/bin/tsc -p tsconfig.demo-server.json",
    "build:lib": "node ./node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "prepack": "yarn build:lib",
    "test": "yarn build:lib && node --test tests/*.test.mjs",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "release": "release-it"
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "express": "^4.17.1",
    "http": "^0.0.1-security",
    "release-it": "^14.10.0",
    "socket.io": "^4.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {}
}
